{
  "name": "codeplanner",
  "displayName": "CodePlanner",
  "description": "Extract text from images with OCR and build structured context files for AI agents. Works in VS Code, Cursor, and compatible IDEs.",
  "version": "0.2.0",
  "publisher": "Naveed",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "ocr",
    "tesseract",
    "image",
    "screenshot",
    "ai",
    "agent",
    "context",
    "prompt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/naveedulislam/codeplanner"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeplanner.extractText",
        "title": "CodePlanner: Extract Text from Image File"
      },
      {
        "command": "codeplanner.extractTextFromClipboard",
        "title": "CodePlanner: Extract Text from Clipboard Image"
      },
      {
        "command": "codeplanner.extractTextFromUri",
        "title": "Extract Text with CodePlanner"
      },
      {
        "command": "codeplanner.captureScreenshot",
        "title": "CodePlanner: Capture Screenshot & Extract Text"
      },
      {
        "command": "codeplanner.newAgentRequest",
        "title": "CodePlanner: New Agent Request"
      },
      {
        "command": "codeplanner.insertWorkspaceContext",
        "title": "CodePlanner: Insert Workspace Context"
      },
      {
        "command": "codeplanner.insertErrors",
        "title": "CodePlanner: Insert Errors & Diagnostics"
      },
      {
        "command": "codeplanner.sendToM365Copilot",
        "title": "Send to Upload Files",
        "category": "CodePlanner"
      },
      {
        "command": "codeplanner.clearCopilotFiles",
        "title": "Clear Staged Files",
        "category": "CodePlanner",
        "icon": "$(clear-all)"
      },
      {
        "command": "codeplanner.copilotRecopyFile",
        "title": "Re-copy to Clipboard",
        "category": "CodePlanner",
        "icon": "$(clippy)"
      },
      {
        "command": "codeplanner.openM365Copilot",
        "title": "Open M365 Copilot Chat",
        "category": "CodePlanner",
        "icon": "$(globe)"
      },
      {
        "command": "codeplanner.copilotCopyAllFiles",
        "title": "Copy All to Clipboard",
        "category": "CodePlanner",
        "icon": "$(copy)"
      }
    ],
    "keybindings": [
      {
        "command": "codeplanner.captureScreenshot",
        "key": "ctrl+shift+alt+4",
        "mac": "ctrl+shift+cmd+4"
      },
      {
        "command": "codeplanner.sendToM365Copilot",
        "key": "ctrl+shift+alt+u",
        "mac": "ctrl+shift+cmd+u"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "codeplanner.copilotFiles",
          "name": "Upload Files",
          "visibility": "collapsed",
          "contextualTitle": "Upload Files"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "codeplanner.extractTextFromUri",
          "when": "resourceExtname =~ /^\\.(png|jpg|jpeg|bmp|tiff|gif|webp)$/i",
          "group": "codeplanner@1"
        },
        {
          "command": "codeplanner.sendToM365Copilot",
          "when": "!explorerResourceIsFolder",
          "group": "codeplanner@2"
        }
      ],
      "view/title": [
        {
          "command": "codeplanner.copilotCopyAllFiles",
          "when": "view == codeplanner.copilotFiles",
          "group": "navigation@1"
        },
        {
          "command": "codeplanner.clearCopilotFiles",
          "when": "view == codeplanner.copilotFiles",
          "group": "navigation@2"
        },
        {
          "command": "codeplanner.openM365Copilot",
          "when": "view == codeplanner.copilotFiles",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "codeplanner.copilotRecopyFile",
          "when": "view == codeplanner.copilotFiles && viewItem == copilotFileItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "CodePlanner",
      "properties": {
        "codeplanner.tesseractLanguage": {
          "type": "string",
          "default": "eng",
          "description": "Tesseract OCR language(s), e.g., 'eng', 'ara', 'eng+ara', 'chi_sim'. Multiple languages separated by '+'."
        },
        "codeplanner.tessDataPath": {
          "type": "string",
          "default": "",
          "description": "Path to local Tesseract language data directory (for offline/air-gapped use). Leave empty to download automatically."
        },
        "codeplanner.openResultInEditor": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open OCR/wireframe results in a new editor tab."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "webpack --mode production --devtool hidden-source-map",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "vsce package",
    "lint": "eslint src"
  },
  "dependencies": {
    "image-size": "^1.2.1",
    "tesseract.js": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
